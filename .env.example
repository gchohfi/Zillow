# ---- Fonte de dados (preferencial: RentCast) ----
# Crie uma conta em https://app.rentcast.io/app/api e cole a chave aqui.
RENTCAST_API_KEY=

# ---- Fonte de dados alternativa (RapidAPI) ----
# Crie uma conta em https://rapidapi.com, assine a API "US Real Estate Listings"
# e cole a chave aqui. Em modo --mock nada disso é necessário.
RAPIDAPI_KEY=
RAPIDAPI_HOST=us-real-estate-listings.p.rapidapi.com

# ---- Alertas por e-mail (opcional, via SMTP) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ---- Alertas por Telegram (opcional) ----
# Crie um bot com o @BotFather e pegue o token; o chat_id você descobre falando com o bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Alertas por WhatsApp via Z-API (opcional) ----
# ZAPI_PHONE deve estar com DDI+DDD+número, só dígitos. Ex.: 15551234567
# ZAPI_CLIENT_TOKEN só é necessário se o token de segurança da conta estiver ativo.
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_PHONE=
WHATSAPP_MAX_OPPORTUNITIES=10
