# ---- Fonte de dados (Fase 1: US Real Estate Listings via RapidAPI) ----
# Crie uma conta em https://rapidapi.com, assine a API "US Real Estate Listings"
# e cole a chave aqui. Em modo --mock nada disso é necessário.
RAPIDAPI_KEY=
RAPIDAPI_HOST=us-real-estate-listings.p.rapidapi.com

# ---- Alertas por e-mail (opcional, via SMTP) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ---- Alertas por Telegram (opcional) ----
# Crie um bot com o @BotFather e pegue o token; o chat_id você descobre falando com o bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
